<UserControl x:Class="ApliqxPos.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ApliqxPos.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="Transparent">
    
    <UserControl.DataContext>
        <vm:InventoryViewModel/>
    </UserControl.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Stats Cards -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Total Products -->
            <Border Grid.Column="0" Style="{StaticResource PremiumCard}" Margin="0,0,12,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" 
                                Background="{StaticResource PrimaryGradient}" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="Package" Width="22" Height="22" 
                                                      Foreground="White" HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource Nav_Products}" 
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalProducts}" 
                               FontSize="28" FontWeight="Bold" 
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Low Stock -->
            <Border Grid.Column="1" Style="{StaticResource PremiumCard}" Margin="6,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" 
                                Background="{StaticResource WarningGradient}" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="AlertCircle" Width="22" Height="22" 
                                                      Foreground="White" HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource Inventory_LowStock}" 
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LowStockCount}" 
                               FontSize="28" FontWeight="Bold" 
                               Foreground="{StaticResource WarningBrush}"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Out of Stock -->
            <Border Grid.Column="2" Style="{StaticResource PremiumCard}" Margin="6,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" 
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#DC2626" Offset="0"/>
                                    <GradientStop Color="#EF4444" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="PackageVariantRemove" Width="22" Height="22" 
                                                      Foreground="White" HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource Inventory_OutOfStock}" 
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding OutOfStockCount}" 
                               FontSize="28" FontWeight="Bold" 
                               Foreground="{StaticResource DangerBrush}"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Total Value -->
            <Border Grid.Column="3" Style="{StaticResource PremiumCard}" Margin="12,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" 
                                Background="{StaticResource SuccessGradient}" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="CurrencyUsd" Width="22" Height="22" 
                                                      Foreground="White" HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource Inventory_StockValue}" 
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,12,0,0">
                        <Run Text="{Binding TotalInventoryValue, StringFormat={}{0:N0}}"/>
                        <Run Text=" د.ع" FontSize="14"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Header Bar -->
        <Border Grid.Row="1" Style="{StaticResource PremiumCard}" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Search -->
                <TextBox Grid.Column="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{DynamicResource Action_Search}"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14"
                         Padding="12,10"
                         MaxWidth="400"
                         HorizontalAlignment="Left">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchProductsCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                
                <!-- Category Filter -->
                <!-- Category Filter with Clear Button -->
                <Grid Grid.Column="1" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="{DynamicResource Product_Category}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="16,0,4,0">
                        <ComboBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding FilterByCategoryCommand}"/>
                        </ComboBox.InputBindings>
                    </ComboBox>
                    
                    <Button Grid.Column="1"
                            Command="{Binding ClearCategoryFilterCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Visibility="{Binding SelectedCategory, Converter={StaticResource NullToVisibilityConverter}}"
                            Margin="0,0,12,0"
                            ToolTip="إلغاء الفلتر">
                        <materialDesign:PackIcon Kind="Close" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>
                
                <!-- Low Stock Button -->
                <Button Grid.Column="2"
                        Command="{Binding FilterLowStockCommand}"
                        ToolTip="{DynamicResource Inventory_LowStock}"
                        Margin="8,0"
                        Height="45"
                        MinWidth="150"
                        Padding="12,0"
                        materialDesign:ButtonAssist.CornerRadius="12"
                        BorderThickness="1">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowLowStockOnly}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource Inventory_LowStock}" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                </Button>
                
                <!-- Out of Stock Button -->
                <Button Grid.Column="3"
                        Command="{Binding FilterOutOfStockCommand}"
                        ToolTip="{DynamicResource Inventory_OutOfStock}"
                        Margin="8,0"
                        Height="45"
                        MinWidth="150"
                        Padding="12,0"
                        materialDesign:ButtonAssist.CornerRadius="12"
                        BorderThickness="1">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowOutOfStockOnly}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/> <!-- Different color for OutOfStock -->
                                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PackageVariantRemove" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource Inventory_OutOfStock}" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <!-- Products Grid -->
        <Border Grid.Row="2" Style="{StaticResource PremiumCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      RowStyle="{StaticResource PremiumDataGridRow}"
                      CellStyle="{StaticResource PremiumDataGridCell}"
                      FlowDirection="LeftToRight">
                
                <DataGrid.Columns>
                    <!-- Product Name -->
                    <DataGridTemplateColumn Width="*" MinWidth="200">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{DynamicResource Label_Name}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="12,8">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                    <TextBlock Text="{Binding Barcode}" FontSize="12" 
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Category -->
                    <DataGridTextColumn Binding="{Binding Category.Name}" Width="140">
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{DynamicResource Product_Category}"/>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>
                    
                    <!-- Current Stock -->
                    <DataGridTemplateColumn Width="120">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{DynamicResource Inventory_Stock}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" CornerRadius="8" HorizontalAlignment="Center"
                                        Background="{Binding Stock, Converter={StaticResource StockToBackgroundConverter}}">
                                    <TextBlock Text="{Binding Stock}" 
                                               FontWeight="Bold" FontSize="16"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Min Stock -->
                    <DataGridTextColumn Binding="{Binding MinStock}" Width="100">
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{DynamicResource Inventory_MinStock}"/>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>
                    
                    <!-- Stock Status -->
                    <DataGridTemplateColumn Width="140">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{DynamicResource Label_Status}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="10,4" CornerRadius="12" HorizontalAlignment="Center"
                                        Background="{Binding Stock, Converter={StaticResource StockToBackgroundConverter}}">
                                    <TextBlock Text="{Binding Stock, Converter={StaticResource StockToStatusConverter}}" 
                                               FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Cost Price -->
                    <DataGridTemplateColumn Width="120">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{DynamicResource Product_CostPrice}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="12,0">
                                    <Run Text="{Binding CostPrice, StringFormat={}{0:N0}}"/>
                                    <Run Text=" " />
                                    <Run Text="{Binding Currency}" FontSize="11" 
                                         Foreground="{StaticResource TextMutedBrush}"/>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Actions -->
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenAdjustStockDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="{DynamicResource Inventory_AdjustStock}"
                                        Width="40" Height="40">
                                    <materialDesign:PackIcon Kind="PackageVariantPlus" Width="20" Height="20"
                                                              Foreground="{StaticResource AccentBrush}"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        
        <!-- Adjust Stock Dialog -->
        <materialDesign:DialogHost IsOpen="{Binding ShowAdjustStockDialog}" 
                                    DialogTheme="Inherit"
                                    CloseOnClickAway="True">
            <materialDesign:DialogHost.DialogContent>
                <Border Background="{StaticResource CardBackgroundBrush}" 
                        CornerRadius="16" 
                        Padding="24"
                        MinWidth="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Dialog Header -->
                        <TextBlock Grid.Row="0" 
                                   Text="{DynamicResource Inventory_AdjustStock}"
                                   Style="{StaticResource SubheaderText}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Product Info -->
                        <Border Grid.Row="1" 
                                Background="{StaticResource SurfaceBrush}" 
                                CornerRadius="12" 
                                Padding="16"
                                Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedProduct.Name}" 
                                           FontWeight="Bold" FontSize="16"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{DynamicResource Inventory_Stock}" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedProduct.Stock}" 
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Form -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,20">
                            <!-- Adjustment Type -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton Content="{DynamicResource Inventory_AddStock}"
                                             IsChecked="{Binding AdjustmentType, Converter={StaticResource EqualityToBoolConverter}, ConverterParameter=Add}"
                                             Style="{StaticResource MaterialDesignChoiceChipRadioButton}"
                                             Margin="0,0,12,0"/>
                                <RadioButton Content="سحب من المخزون"
                                             IsChecked="{Binding AdjustmentType, Converter={StaticResource EqualityToBoolConverter}, ConverterParameter=Remove}"
                                             Style="{StaticResource MaterialDesignChoiceChipRadioButton}"/>
                            </StackPanel>
                            
                            <!-- Quantity -->
                            <TextBox Text="{Binding AdjustmentQuantity}"
                                     materialDesign:HintAssist.Hint="{DynamicResource Label_Quantity}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="18"
                                     Margin="0,0,0,12"/>
                            
                            <!-- Notes -->
                            <TextBox Text="{Binding AdjustmentNotes}"
                                     materialDesign:HintAssist.Hint="{DynamicResource Label_Notes}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </StackPanel>
                        
                        <!-- Dialog Actions -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CloseDialogCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Content="{DynamicResource Action_Cancel}"
                                    Margin="0,0,12,0"/>
                            <Button Command="{Binding AdjustStockCommand}"
                                    Style="{StaticResource GradientButton}"
                                    Content="{DynamicResource Action_Save}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>
    </Grid>
</UserControl>
