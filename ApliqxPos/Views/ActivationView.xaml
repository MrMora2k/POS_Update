<Window x:Class="ApliqxPos.Views.ActivationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ApliqxPos.ViewModels"
        Title="تفعيل البرنامج" Height="620" Width="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Window.DataContext>
        <vm:ActivationViewModel/>
    </Window.DataContext>

    <Border CornerRadius="20" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Branding -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A5F" Offset="0"/>
                        <GradientStop Color="#6C3EE8" Offset="0.7"/>
                        <GradientStop Color="#3B82F6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Decorative -->
                    <Ellipse Width="280" Height="280" Opacity="0.07"
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0">
                        <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="200" Height="200" Opacity="0.08"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-70,-70">
                        <Ellipse.Fill><SolidColorBrush Color="White"/></Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <!-- Shield Icon -->
                        <Border Width="100" Height="100" CornerRadius="24"
                                HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.15"/>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="ShieldKeyOutline" Width="56" Height="56"
                                                     Foreground="White" HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="تفعيل البرنامج" FontSize="26" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="ApliqX POS" FontSize="14" Foreground="#90CAF9"
                                   HorizontalAlignment="Center" Margin="0,6,0,32"/>

                        <!-- Steps -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="#FFFFFF26" VerticalAlignment="Center">
                                    <TextBlock Text="1" Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="احصل على مفتاح التفعيل من المزود" 
                                           Foreground="#E3F2FD" Margin="12,0,0,0" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="#FFFFFF26" VerticalAlignment="Center">
                                    <TextBlock Text="2" Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="أدخل بيانات الحساب المرتبطة بالمفتاح"
                                           Foreground="#E3F2FD" Margin="12,0,0,0" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="#FFFFFF26" VerticalAlignment="Center">
                                    <TextBlock Text="3" Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="اضغط تفعيل واستمتع بالبرنامج"
                                           Foreground="#E3F2FD" Margin="12,0,0,0" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Panel: Activation Form -->
            <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
                <Grid>
                    <!-- Close Button -->
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            VerticalAlignment="Top" HorizontalAlignment="Left"
                            Click="Close_Click" Margin="8,8,0,0" Opacity="0.6">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>

                    <StackPanel VerticalAlignment="Center" Margin="36,0">
                        <!-- Header -->
                        <materialDesign:PackIcon Kind="KeyVariant" Width="44" Height="44"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="أدخل بيانات التفعيل"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="مفتاح التفعيل مرتبط بهذا الجهاز"
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,28"/>

                        <!-- License Key -->
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="مفتاح التفعيل (License Key)"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="Key"
                                 Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <!-- Username -->
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="اسم المستخدم (Username)"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="Account"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <!-- Password -->
                        <PasswordBox x:Name="UserPasswordBox"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     materialDesign:HintAssist.Hint="كلمة المرور (Password)"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="Lock"
                                     PasswordChanged="UserPasswordBox_PasswordChanged"
                                     Margin="0,0,0,20"/>

                        <!-- Error Message -->
                        <Border CornerRadius="8" Padding="12,8"
                                Background="#FFF3F3" Margin="0,0,0,16"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle" Width="18" Height="18"
                                                         Foreground="#E53935" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935"
                                           Margin="8,0,0,0" TextWrapping="Wrap" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Activate Button -->
                        <Button Command="{Binding ActivateCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Height="48" FontSize="15" FontWeight="SemiBold"
                                Style="{StaticResource GradientButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ShieldCheck" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="تفعيل البرنامج" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Loader / Status -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,14,0,0" MinHeight="24">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         IsIndeterminate="True" Width="22" Height="22"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding StatusMessage}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="13"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>

                        <!-- Skip Button -->
                        <Button Click="Skip_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Content="تخطي (للمسؤولين فقط)"
                                Margin="0,8,0,0" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

