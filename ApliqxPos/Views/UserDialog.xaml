<UserControl x:Class="ApliqxPos.Views.UserDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ApliqxPos.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             Width="350">
    <UserControl.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,8"/>
        </Style>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
            <Setter Property="Margin" Value="0,8"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding IsEditMode, Converter={StaticResource BoolToTextConverter}, ConverterParameter='تعديل مستخدم|إضافة مستخدم جديد'}"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="اسم المستخدم"
                     IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"/>

            <PasswordBox x:Name="PasswordBox"
                         materialDesign:HintAssist.Hint="كلمة المرور (اتركها فارغة لعدم التغيير)"/>

            <TextBox Text="{Binding PinCode, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="رمز PIN (اختياري)"/>

            <ComboBox ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRole}"
                      materialDesign:HintAssist.Hint="الصلاحية"
                      DisplayMemberPath="."/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Static sys:Boolean.FalseString}"
                    Content="إلغاء"/>
            
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Static sys:Boolean.TrueString}"
                    Content="حفظ"
                    Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>

