<UserControl x:Class="ApliqxPos.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ApliqxPos.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent">
    
    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Style="{StaticResource PremiumCard}" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <materialDesign:PackIcon Kind="Cog" Width="28" Height="28" 
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                        <TextBlock Text="{DynamicResource Nav_Settings}" 
                                   Style="{StaticResource SubheaderText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Save Button in Header -->
                    <Button Grid.Column="1" 
                            Command="{Binding SaveSettingsCommand}"
                            Style="{StaticResource GradientButton}"
                            Padding="24,8"
                            Height="40"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Settings_SaveSettings}" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Two Column Layout -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <!-- Language & Theme Settings -->
                    <Border Style="{StaticResource PremiumCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Settings_Language}" 
                                       Style="{StaticResource SubheaderText}"
                                       Margin="0,0,0,16"/>
                            
                            <!-- Language Selection -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <RadioButton Content="العربية"
                                             IsChecked="{Binding IsArabic}"
                                             Command="{Binding SetLanguageCommand}"
                                             CommandParameter="ar"
                                             Style="{StaticResource MaterialDesignChoiceChipRadioButton}"
                                             Margin="0,0,12,0"
                                             FontSize="14"/>
                                <RadioButton Content="English"
                                             IsChecked="{Binding IsEnglish}"
                                             Command="{Binding SetLanguageCommand}"
                                             CommandParameter="en"
                                             Style="{StaticResource MaterialDesignChoiceChipRadioButton}"
                                             FontSize="14"/>
                            </StackPanel>
                            
                            <Separator Margin="0,0,0,20" Background="{StaticResource GlassBorderBrush}"/>
                            
                            <!-- Theme -->
                            <TextBlock Text="{DynamicResource Settings_Theme}" 
                                       Style="{StaticResource SubheaderText}"
                                       Margin="0,0,0,16"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton IsChecked="{Binding IsDarkTheme}"
                                              Command="{Binding ToggleThemeCommand}"
                                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                              Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Settings_DarkMode}" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Typography Settings -->
                    <Border Style="{StaticResource PremiumCard}" Margin="0,16,8,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Settings_Typography}" 
                                       Style="{StaticResource SubheaderText}"
                                       Margin="0,0,0,16"/>
                            
                            <!-- Font Family -->
                            <ComboBox ItemsSource="{Binding FontFamilies}"
                                      SelectedItem="{Binding SelectedFontFamily}"
                                      materialDesign:HintAssist.Hint="{DynamicResource Settings_FontFamily}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,0,0,20"/>
                            
                            <!-- Font Sizes -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="{DynamicResource Settings_FontSize_Header}" VerticalAlignment="Center" Width="100"/>
                                <Slider Grid.Column="1" Value="{Binding FontSizeHeader}" Minimum="18" Maximum="48" Margin="8,0" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                <TextBlock Grid.Column="2" Text="{Binding FontSizeHeader}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="{DynamicResource Settings_FontSize_Button}" VerticalAlignment="Center" Width="100"/>
                                <Slider Grid.Column="1" Value="{Binding FontSizeButton}" Minimum="10" Maximum="24" Margin="8,0" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                <TextBlock Grid.Column="2" Text="{Binding FontSizeButton}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="{DynamicResource Settings_FontSize_Body}" VerticalAlignment="Center" Width="100"/>
                                <Slider Grid.Column="1" Value="{Binding FontSizeBody}" Minimum="10" Maximum="24" Margin="8,0" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                <TextBlock Grid.Column="2" Text="{Binding FontSizeBody}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <Button Command="{Binding ResetFontsCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Restore" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Settings_ResetFonts}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Currency Settings -->
                <Border Grid.Column="1" Style="{StaticResource PremiumCard}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings_Currency}" 
                                   Style="{StaticResource SubheaderText}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Primary Currency -->
                        <TextBox Text="{Binding PrimaryCurrency}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Settings_PrimaryCurrency}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,12"/>
                        
                        <!-- Exchange Rate -->
                        <TextBox Text="{Binding ExchangeRate}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Settings_ExchangeRate}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,20"/>
                        
                        <Separator Margin="0,0,0,20" Background="{StaticResource GlassBorderBrush}"/>
                        
                        <!-- Tax Settings -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ToggleButton IsChecked="{Binding EnableTax}"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource Settings_EnableTax}" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBox Text="{Binding TaxRate}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Settings_TaxRate}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 IsEnabled="{Binding EnableTax}"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Business Info -->
            <Border Grid.Row="2" Style="{StaticResource PremiumCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_ShopInfo}" 
                               Style="{StaticResource SubheaderText}"
                               Margin="0,0,0,16"/>
                    
                    <!-- Restaurant Mode Toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ToggleButton IsChecked="{Binding IsRestaurantMode}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      Margin="0,0,12,0"/>
                        <TextBlock Text="{DynamicResource Settings_RestaurantMode}" 
                                   VerticalAlignment="Center"
                                   Style="{StaticResource BodyText}"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0"
                                 Text="{Binding BusinessName}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Label_Name}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,8,0"/>
                        
                        <TextBox Grid.Column="1"
                                 Text="{Binding BusinessPhone}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Label_Phone}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="4,0"/>
                        
                        <TextBox Grid.Column="2"
                                 Text="{Binding BusinessAddress}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Label_Address}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Print Settings -->
            <Border Grid.Row="3" Style="{StaticResource PremiumCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_PrintSettings}" 
                               Style="{StaticResource SubheaderText}"
                               Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Print Output Type -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="{DynamicResource Settings_OutputType}" 
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" Margin="0,0,0,8"/>
                             <StackPanel Orientation="Horizontal">
                                <RadioButton Content="{DynamicResource Action_Print}"
                                             IsChecked="{Binding PrintOutputType, Converter={StaticResource EqualityConverter}, ConverterParameter=Printer}"
                                             Style="{StaticResource MaterialDesignChoiceChipRadioButton}"
                                             Command="{Binding SetPrintOutputTypeCommand}"
                                             CommandParameter="Printer"
                                             Margin="0,0,12,0"/>
                                <RadioButton Content="PDF"
                                             IsChecked="{Binding PrintOutputType, Converter={StaticResource EqualityConverter}, ConverterParameter=PDF}"
                                             Style="{StaticResource MaterialDesignChoiceChipRadioButton}"
                                             Command="{Binding SetPrintOutputTypeCommand}"
                                             CommandParameter="PDF"/>
                            </StackPanel>
                            
                            <!-- Paper Size selection -->
                            <TextBlock Text="{DynamicResource Settings_PaperSize}" 
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" Margin="0,16,0,8"/>
                            <ComboBox ItemsSource="{Binding AvailablePaperSizes}"
                                      SelectedItem="{Binding ReceiptWidth}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="{DynamicResource Settings_PaperSizeSelection}"/>
                        </StackPanel>
                        
                        <!-- Printer/PDF Settings -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <!-- Printer Selection (visible when PrintOutputType is Printer) -->
                            <StackPanel Visibility="{Binding PrintOutputType, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Printer}">
                                <TextBlock Text="{DynamicResource Settings_SelectPrinter}" 
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding AvailablePrinters}"
                                          SelectedItem="{Binding SelectedPrinter}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          materialDesign:HintAssist.Hint="{DynamicResource Settings_PrinterSelection}"/>

                                <!-- Kitchen Printer -->
                                <TextBlock Text="طابعة المطبخ" 
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" Margin="0,16,0,8"/>
                                <ComboBox ItemsSource="{Binding AvailablePrinters}"
                                          SelectedItem="{Binding SelectedKitchenPrinter}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          materialDesign:HintAssist.Hint="اختر طابعة المطبخ"/>
                            </StackPanel>
                            
                            <!-- PDF Path (visible when PrintOutputType is PDF) -->
                            <StackPanel Visibility="{Binding PrintOutputType, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=PDF}">
                                <TextBlock Text="{DynamicResource Settings_PdfFolder}" 
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding PdfSavePath}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="{DynamicResource Settings_SavePath}"
                                             IsReadOnly="True"/>
                                    <Button Grid.Column="1"
                                            Command="{Binding BrowsePdfPathCommand}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Margin="8,0,0,0"
                                            ToolTip="{DynamicResource Settings_SelectFolder}">
                                        <materialDesign:PackIcon Kind="FolderOpen" Width="20" Height="20"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <Button Content="{DynamicResource Settings_AdvancedPrint}"
                            Click="OpenAdvancedPrintSettings_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PrinterSettings" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Database Operations -->
            <Border Grid.Row="4" Style="{StaticResource PremiumCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_Database}" 
                               Style="{StaticResource SubheaderText}"
                               Margin="0,0,0,16"/>
                    
                    <!-- Database Info -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            CornerRadius="12" 
                            Padding="16"
                            Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- DB Size -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Settings_DatabaseSize}" 
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding DatabaseSize}" 
                                           FontSize="18" FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <!-- Last Backup -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{DynamicResource Settings_LastBackup}" 
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding LastBackup}" 
                                           FontSize="18" FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <!-- DB Path -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource Settings_DatabaseLocation}" 
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding DatabasePath}" 
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding DatabasePath}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Database Actions -->
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding BackupDatabaseCommand}"
                                Style="{StaticResource GradientButton}"
                                Margin="0,0,12,0"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseExport" Width="18" Height="18" 
                                                          Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Settings_Backup}"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Command="{Binding OpenBackupFolderCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Folder" Width="18" Height="18" 
                                                          Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Settings_OpenBackupFolder}"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Command="{Binding ResetDatabaseCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource DangerBrush}"
                                BorderBrush="{StaticResource DangerBrush}"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseRemove" Width="18" Height="18" 
                                                          Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Settings_ResetDatabase}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Separator Margin="0,20" Background="{StaticResource GlassBorderBrush}"/>

                    <!-- Check for Updates -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Update" Width="24" Height="24"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="تحديثات التطبيق" FontWeight="Bold"/>
                            <TextBlock Text="{Binding AppVersion}" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                        <Button Command="{Binding CheckForUpdatesCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="20,0,0,0"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Update" Width="18" Height="18" Margin="0,0,8,0"/>
                                <TextBlock Text="التحقق من التحديثات"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>


        </Grid>
        </ScrollViewer>
</UserControl>
