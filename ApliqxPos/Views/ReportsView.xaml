<UserControl x:Class="ApliqxPos.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ApliqxPos.ViewModels"

             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="Transparent">
    
    <UserControl.DataContext>
        <vm:ReportsViewModel/>
    </UserControl.DataContext>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header Bar with Period Filter -->
            <Border Grid.Row="0" Style="{StaticResource PremiumCard}" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartAreaspline" Width="28" Height="28" 
                                                  Foreground="{StaticResource AccentBrush}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                        <TextBlock Text="{DynamicResource Nav_Reports}" 
                                   Style="{StaticResource SubheaderText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Period Buttons & Custom Dates -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}"
                                    materialDesign:HintAssist.Hint="من تاريخ"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                    Width="120" Margin="0,0,8,0"/>
                        
                        <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}"
                                    materialDesign:HintAssist.Hint="إلى تاريخ"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                    Width="120" Margin="0,0,16,0"/>

                        <Button Command="{Binding LoadDataCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="تحديث البيانات"
                                Margin="0,0,16,0">
                            <materialDesign:PackIcon Kind="Refresh" Foreground="{StaticResource AccentBrush}" Width="24" Height="24"/>
                        </Button>

                        <Button Content="يومي"
                                Command="{Binding SetPeriodCommand}"
                                CommandParameter="Daily"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,0"/>
                        <Button Content="أسبوعي"
                                Command="{Binding SetPeriodCommand}"
                                CommandParameter="Weekly"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,0"/>
                        <Button Content="شهري"
                                Command="{Binding SetPeriodCommand}"
                                CommandParameter="Monthly"
                                Style="{StaticResource GradientButton}"
                                Margin="0,0,8,0"/>
                        <Button Content="سنوي"
                                Command="{Binding SetPeriodCommand}"
                                CommandParameter="Yearly"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Stats Cards Row 1 & 2 combined for better layout -->
            <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,16">
                <!-- Total Sales -->
                <Border Style="{StaticResource PremiumCard}" Margin="0,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="{StaticResource PrimaryGradient}" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="CashMultiple" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Report_TotalSales}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,4,0,0">
                                <Run Text="{Binding TotalSales, StringFormat={}{0:N0}}"/><Run Text=" د.ع" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Total Profit -->
                <Border Style="{StaticResource PremiumCard}" Margin="4,0,4,8">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="{StaticResource SuccessGradient}" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="TrendingUp" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Report_TotalProfit}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource SuccessBrush}">
                                <Run Text="{Binding TotalProfit, StringFormat={}{0:N0}}"/><Run Text=" د.ع" FontSize="10"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Transactions -->
                <Border Style="{StaticResource PremiumCard}" Margin="4,0,4,8">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="{StaticResource CyanGradient}" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="Receipt" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Report_Transactions}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalTransactions}" FontSize="16" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Cancelled / Refunds -->
                <Border Style="{StaticResource PremiumCard}" Margin="4,0,4,8">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="{StaticResource DangerBrush}" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="Cancel" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="مرتجعات وملغاة" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalCancelled}" FontSize="16" FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource DangerBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Debt Created -->
                <Border Style="{StaticResource PremiumCard}" Margin="8,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="{StaticResource WarningBrush}" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="AccountCreditCard" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="إجمالي الديون (الفترة)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource WarningBrush}">
                                <Run Text="{Binding TotalDebtCreated, StringFormat={}{0:N0}}"/><Run Text=" د.ع" FontSize="10"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Charts and Detailed Info -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Trend Chart -->
                    <RowDefinition Height="Auto"/> <!-- Pie Charts / Top Products -->
                    <RowDefinition Height="Auto"/> <!-- Recent Sales Table -->
                </Grid.RowDefinitions>

                <!-- Sales Trend -->
                <Border Grid.Row="0" Style="{StaticResource PremiumCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Reports_SalesTrend}" Style="{StaticResource SubheaderText}" Margin="0,0,0,16"/>
                        <Border Height="300">
                            <ContentControl x:Name="SalesTrendChartHost" FlowDirection="LeftToRight" />
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top Selling Products -->
                    <Border Grid.Column="0" Style="{StaticResource PremiumCard}" Margin="0,0,8,0" Height="400">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Reports_TopProducts}" Style="{StaticResource SubheaderText}" Margin="0,0,0,16"/>
                            <ContentControl x:Name="TopProductsChartHost" Height="320" FlowDirection="LeftToRight" />
                        </StackPanel>
                    </Border>

                    <!-- Revenue By Product (Pie) -->
                    <Border Grid.Column="1" Style="{StaticResource PremiumCard}" Margin="8,0,0,0" Height="400">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Reports_RevenueByProduct}" Style="{StaticResource SubheaderText}" Margin="0,0,0,16"/>
                            <ContentControl x:Name="CategoryBreakdownChartHost" Height="320" FlowDirection="LeftToRight" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Recent Transactions -->
                <Border Grid.Row="2" Style="{StaticResource PremiumCard}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Reports_RecentTransactions}" Style="{StaticResource SubheaderText}" Margin="0,0,0,16"/>
                        <DataGrid ItemsSource="{Binding RecentSales}" 
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Style="{StaticResource MaterialDesignDataGrid}"
                                  HeadersVisibility="Column"
                                  Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Id}" Width="Auto">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{DynamicResource Header_InvoiceNumber}"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding SaleDate, StringFormat={}{0:yyyy/MM/dd HH:mm}}" Width="*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{DynamicResource Label_Date}"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding CustomerName}" Width="*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{DynamicResource Header_Customer}"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding TotalAmount, StringFormat={}{0:N0} د.ع}" Width="*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{DynamicResource Sale_Amount}"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding PaymentMethod}" Width="Auto">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="دفع"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{DynamicResource Header_Status}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,4" CornerRadius="8" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource SuccessGradient}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Refunded">
                                                                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" FontWeight="Bold" TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
