<Window x:Class="ApliqxPos.Views.ThemeCustomizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تخصيص الألوان"
        Width="540" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border Background="{DynamicResource WindowBackgroundBrush}" 
            CornerRadius="16" 
            BorderBrush="{DynamicResource GlassBorderBrush}" 
            BorderThickness="1"
            Margin="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" 
                    CornerRadius="16,16,0,0" Padding="20,14"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Palette" Width="24" Height="24" 
                                                  Foreground="{DynamicResource AccentBrush}" 
                                                  VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="تخصيص ألوان التطبيق" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Left" VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Click="CloseButton_Click" Width="32" Height="32">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Color Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12">
                <StackPanel x:Name="ColorItemsPanel" />
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" 
                    CornerRadius="0,0,16,16" Padding="20,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Click="ResetColors_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="{DynamicResource WarningBrush}"
                            BorderBrush="{DynamicResource WarningBrush}"
                            Margin="0,0,12,0" Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Restore" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="استعادة الافتراضي" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button Click="CloseButton_Click"
                            Style="{StaticResource GradientButton}"
                            Padding="24,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Check" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="تم" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

