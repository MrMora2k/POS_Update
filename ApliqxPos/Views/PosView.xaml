<UserControl x:Class="ApliqxPos.Views.PosView"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:sys="clr-namespace:System;assembly=mscorlib"
              xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
              xmlns:vm="clr-namespace:ApliqxPos.ViewModels"
              xmlns:controls="clr-namespace:ApliqxPos.Controls"
              xmlns:converters="clr-namespace:ApliqxPos.Converters"
              xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
              mc:Ignorable="d" 
              d:DesignHeight="800" d:DesignWidth="1200"
              Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InvertedBoolConverter"/>
        <Style TargetType="RadioButton" x:Key="OrderTypeRadio" BasedOn="{StaticResource MaterialDesignTabRadioButton}">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:PosViewModel/>
    </UserControl.DataContext>
    
    <!-- ... (rest of DialogHost) ... -->
    
    <!-- ... (inside Cart Column Grid) ... -->
    <!-- ... (rest of DialogHost) ... -->
    
    <materialDesign:DialogHost IsOpen="{Binding IsPrintPreviewOpen}" CloseOnClickAway="True">
        <materialDesign:DialogHost.DialogContent>
            <!-- PREVIEW DIALOG -->
            <Border Width="400" Padding="0" Background="White" CornerRadius="8" ClipToBounds="True">
                <Border.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Black"/>
                    </Style>
                </Border.Resources>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Info -->
                        <RowDefinition Height="*"/>    <!-- Items -->
                        <RowDefinition Height="Auto"/> <!-- Total -->
                        <RowDefinition Height="Auto"/> <!-- Actions -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Receipt" Width="24" Height="24" Margin="0,0,10,0" Foreground="White"/>
                            <TextBlock Text="{DynamicResource POS_InvoicePreview}" FontWeight="Bold" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Info -->
                    <Grid Grid.Row="1" Margin="20,16,20,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource POS_DateLabel}" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat=yyyy/MM/dd}" Foreground="#333"/>
                        </StackPanel>
                        <Border Background="#EEE" CornerRadius="4" Padding="8,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource POS_Draft}" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                        </Border>
                    </Grid>

                    <Separator Grid.Row="1" VerticalAlignment="Bottom" Margin="0,0,0,-8"/>

                    <!-- Items -->
                    <ScrollViewer Grid.Row="2" MaxHeight="300" Margin="0,10" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CartItems}" Margin="20,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ProductName}" TextTrimming="CharacterEllipsis" FontWeight="Medium" Foreground="Black"/>
                                        <TextBlock Grid.Column="1" Margin="10,0" Foreground="#555">
                                            <Run Text="x"/>
                                            <Run Text="{Binding Quantity}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Text="{Binding Subtotal, StringFormat={}{0:N0}}" FontWeight="Bold" Foreground="Black"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Total -->
                    <Border Grid.Row="3" BorderBrush="#EEE" BorderThickness="0,1,0,0" Margin="20,0">
                        <Grid Margin="0,12">
                            <TextBlock Text="{DynamicResource POS_GrandTotal}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Foreground="Black"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Total, StringFormat={}{0:N0}}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock Text="{DynamicResource Currency_IQD_Symbol}" VerticalAlignment="Bottom" Margin="4,0,0,4" FontSize="12" Foreground="#555"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Actions -->
                    <Border Grid.Row="4" Background="#F5F5F5" Padding="16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Command="{Binding PayAndPrintCommand}" 
                                    Style="{StaticResource MaterialDesignRaisedButton}" 
                                    Content="{DynamicResource POS_PrintAndConfirm}" 
                                    Width="140"
                                    Margin="0,0,10,0"/>
                            
                            <Button Command="{Binding ClosePrintPreviewCommand}" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}" 
                                    Content="{DynamicResource Action_Close}" 
                                    Width="80"
                                    Foreground="White"
                                    Background="#444"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </materialDesign:DialogHost.DialogContent>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Products Section -->
                <ColumnDefinition Width="2*"/>
                <!-- Cart Section -->
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>
            
            <!-- =============================================== -->
            <!-- Products Section                               -->
            <!-- =============================================== -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Search Bar -->
                <Border Grid.Row="0" Style="{StaticResource PremiumCard}" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Search_Products}"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="14"
                                 Padding="12,10">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchProductsCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        
                        <Button Grid.Column="1"
                                Command="{Binding SearchProductsCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="48" Height="48"
                                Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="Magnify" Width="24" Height="24"/>
                        </Button>
                    </Grid>
                </Border>
                
                <!-- Categories -->
                <Border Grid.Row="1" Margin="0,0,0,16">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.FilterByCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Content="{Binding Name}"
                                            Margin="0,0,8,0"
                                            Padding="16,8"
                                            Height="40"
                                            MinWidth="80"
                                            FontWeight="Medium"
                                            materialDesign:ButtonAssist.CornerRadius="10"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                
                <!-- Products Grid -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Padding="0"
                                        Width="180" Height="220"
                                        Margin="6">
                                    <Border Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="12"
                                            Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Product Image/Icon -->
                                            <Border Grid.Row="0" 
                                                    Width="80" Height="80" 
                                                    CornerRadius="12"
                                                    Background="{DynamicResource GlassBrush}"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,12"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <!-- Fallback Icon (shown when no image) -->
                                                    <materialDesign:PackIcon Kind="Package" 
                                                                              Width="36" Height="36"
                                                                              Foreground="{DynamicResource AccentBrush}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                    <!-- Product Image -->
                                                    <Image Source="{Binding ImagePath}" 
                                                           Stretch="UniformToFill"
                                                           Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Product Name -->
                                            <TextBlock Grid.Row="1" 
                                                       Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="36"
                                                       Margin="0,4,0,0"/>
                                            
                                            <!-- Price & Stock -->
                                            <StackPanel Grid.Row="2" Margin="0,8,0,0">
                                                <TextBlock Text="{Binding SalePrice, StringFormat={}{0:N0}}"
                                                           FontWeight="Bold"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           TextAlignment="Center"/>
                                                <TextBlock TextAlignment="Center" FontSize="11" 
                                                           Foreground="{DynamicResource TextMutedBrush}">
                                                    <Run Text="{DynamicResource Product_Stock}"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding Stock}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- Empty State -->
                <Border Grid.Row="2" 
                        Visibility="{Binding Products.Count, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=0}"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="PackageVariant" Width="64" Height="64"
                                                  Foreground="{DynamicResource TextMutedBrush}"
                                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource NoProducts}" 
                                   Style="{StaticResource SubheaderText}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- =============================================== -->
            <!-- Cart Section                                   -->
            <!-- =============================================== -->
            <Border Grid.Column="1" 
                    Style="{StaticResource PremiumCard}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Restaurant Mode -->
                        <RowDefinition Height="Auto"/> <!-- Customer Selection -->
                        <RowDefinition Height="Auto"/> <!-- Tabs -->
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- List -->
                        <RowDefinition Height="Auto"/> <!-- Totals -->
                        <RowDefinition Height="Auto"/> <!-- Actions -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Restaurant Mode Controls -->
                    <Border Grid.Row="0" Margin="0,0,0,8" Padding="8" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,0,12,12"
                            Visibility="{Binding IsRestaurantMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <!-- Order Type Selection -->
                            <UniformGrid Rows="1" Margin="0,0,0,8">
                                <RadioButton Content="{DynamicResource OrderType_InStore}" 
                                             IsChecked="{Binding IsDineIn, Mode=OneWay}"
                                             Command="{Binding SetOrderTypeCommand}" CommandParameter="DineIn"
                                             Style="{StaticResource OrderTypeRadio}"/>
                                
                                <RadioButton Content="سفري" 
                                             IsChecked="{Binding IsTakeaway, Mode=OneWay}"
                                             Command="{Binding SetOrderTypeCommand}" CommandParameter="Takeaway"
                                             Style="{StaticResource OrderTypeRadio}"/>
                                
                                <RadioButton Content="توصيل" 
                                             IsChecked="{Binding IsDelivery, Mode=OneWay}"
                                             Command="{Binding SetOrderTypeCommand}" CommandParameter="Delivery"
                                             Style="{StaticResource OrderTypeRadio}"/>
                            </UniformGrid>

                            <!-- Dine-In Fields -->
                            <Grid Visibility="{Binding IsDineIn, Converter={StaticResource BoolToVis}}">
                                <TextBox Text="{Binding TableNumber, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="{DynamicResource TableNumber}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Margin="4"/>
                            </Grid>

                            <!-- Delivery Fields -->
                            <Grid Visibility="{Binding IsDelivery, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0" Grid.Column="0"
                                         Text="{Binding DriverName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="{DynamicResource DriverName}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Margin="4"/>

                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="{DynamicResource CustomerPhone}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Margin="4"/>

                                <TextBox Grid.Row="1" Grid.ColumnSpan="2"
                                         Text="{Binding DeliveryAddress, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="{DynamicResource DeliveryAddress}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Margin="4"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Row 1: Customer & Payment Method -->
                    <Grid Grid.Row="1" Margin="16,0,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Customer Selection -->
                        <ComboBox Grid.Column="0" ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="Name"
                                  materialDesign:HintAssist.Hint="اختيار الزبون (اختياري)"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  materialDesign:TextFieldAssist.HasClearButton="True"/>

                        <!-- Payment Method -->
                        <ComboBox Grid.Column="2" 
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding PaymentMethod, Mode=TwoWay}"
                                  materialDesign:HintAssist.Hint="طريقة الدفع"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                            <ComboBoxItem Tag="Cash" IsSelected="True">نقدي (Cash)</ComboBoxItem>
                            <ComboBoxItem Tag="Debt">آجل (دين)</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <!-- Row 2: Invoice Tabs -->
                    <UniformGrid Grid.Row="2" Rows="1" Margin="0,8,0,8">
                        <!-- Invoice 1 -->
                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipRadioButton}" 
                                     Content="{DynamicResource POS_InvoiceTab1}" 
                                     Margin="4,0"
                                     IsChecked="True"
                                     Command="{Binding SelectSessionCommand}" CommandParameter="0"/>
                        <!-- Invoice 2 -->
                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipRadioButton}" 
                                     Content="{DynamicResource POS_InvoiceTab2}" 
                                     Margin="4,0"
                                     Command="{Binding SelectSessionCommand}" CommandParameter="1"/>
                        <!-- Invoice 3 -->
                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipRadioButton}" 
                                     Content="{DynamicResource POS_InvoiceTab3}" 
                                     Margin="4,0"
                                     Command="{Binding SelectSessionCommand}" CommandParameter="2"/>
                        <!-- Invoice 4 -->
                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipRadioButton}" 
                                     Content="{DynamicResource POS_InvoiceTab4}" 
                                     Margin="4,0"
                                     Command="{Binding SelectSessionCommand}" CommandParameter="3"/>
                    </UniformGrid>
                    
                    <!-- Cart Header -->
                    <Border Grid.Row="3" Padding="20,16" Background="{DynamicResource GlassBrush}"
                            CornerRadius="16,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cart" Width="24" Height="24" 
                                                          Foreground="{DynamicResource AccentBrush}"
                                                          VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Cart}" 
                                           Style="{StaticResource SubheaderText}"
                                           Margin="12,0,0,0"/>
                                <Border Background="{DynamicResource AccentBrush}" 
                                        CornerRadius="10"
                                        Padding="8,2"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CartItems.Count}" 
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                            </StackPanel>
                            
                            <Button Grid.Column="1"
                                    Command="{Binding ClearCartCommand}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="{DynamicResource ClearCart}">
                                <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20"
                                                          Foreground="{DynamicResource DangerBrush}"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Cart Items -->
                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Padding="16,8">
                        <ItemsControl ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="10"
                                            Padding="12"
                                            Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ProductName}" 
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}">
                                                    <Run Text="{Binding UnitPrice, StringFormat={}{0:N0}}"/>
                                                    <Run Text=" × "/>
                                                    <Run Text="{Binding Quantity}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N0}}"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="32" Height="32">
                                                    <materialDesign:PackIcon Kind="Minus" Width="16" Height="16"/>
                                                </Button>
                                                
                                                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                         FontWeight="Bold" FontSize="14"
                                                         VerticalAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         Margin="8,0"
                                                         Width="60"
                                                         Style="{StaticResource MaterialDesignTextBox}"
                                                         IsReadOnly="False"
                                                         Cursor="IBeam">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.OpenNumericKeypadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                                  CommandParameter="{Binding}"/>
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                </TextBox>
                                                
                                                <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="32" Height="32">
                                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                                                </Button>
                                                
                                                <Button Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="32" Height="32"
                                                        Margin="8,0,0,0">
                                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                                              Foreground="{DynamicResource DangerBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Cart Empty State -->
                    <Border Grid.Row="4" 
                            Visibility="{Binding CartItems.Count, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=0}"
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="CartOutline" Width="48" Height="48"
                                                      Foreground="{DynamicResource TextMutedBrush}"
                                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource CartEmpty}" 
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Totals -->
                    <Border Grid.Row="5" Padding="16" Background="{DynamicResource SurfaceBrush}">
                        <StackPanel>
                            <!-- Subtotal -->
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Subtotal}" 
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding Subtotal, StringFormat={}{0:N0}}"
                                           FontWeight="SemiBold"/>
                            </Grid>
                            
                            <!-- Discount -->
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Discount}" 
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Grid.Column="1" 
                                         Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}"
                                         Foreground="{DynamicResource DangerBrush}"
                                         FontWeight="Bold"
                                         Width="80"
                                         HorizontalContentAlignment="Right"
                                         materialDesign:HintAssist.Hint="0"
                                         Style="{StaticResource MaterialDesignTextBox}"/>
                            </Grid>
                            <!-- Paid Amount (Optional) -->
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="الواصل (اختياري)" 
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Grid.Column="1" 
                                         Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged}"
                                         Foreground="{DynamicResource SuccessBrush}"
                                         FontWeight="Bold"
                                         Width="80"
                                         HorizontalContentAlignment="Right"
                                         materialDesign:HintAssist.Hint="حسب الإجمالي"
                                         Style="{StaticResource MaterialDesignTextBox}"/>
                            </Grid>
                            
                            <Separator Margin="0,8" Background="{DynamicResource GlassBorderBrush}"/>
                            
                            <!-- Total -->
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Total}" 
                                           Style="{StaticResource SubheaderText}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Total, StringFormat={}{0:N0}}"
                                               Style="{StaticResource PriceText}"
                                               FontSize="22"/>
                                    <TextBlock Text=" د.ع" 
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,0,4"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Checkout & Actions -->
                    <Border Grid.Row="6" Padding="16" CornerRadius="0,0,16,16">
                        <StackPanel>
                            <!-- Primary: Pay & Print -->
                            <Button Command="{Binding PayAndPrintCommand}"
                                    Style="{StaticResource GradientButton}"
                                    Height="50"
                                    FontSize="16"
                                    Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PrinterPos" Width="24" Height="24" Margin="0,0,10,0"/>
                                    <TextBlock Text="{DynamicResource POS_PayAndPrint}"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Secondary Actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Preview/Print Only -->
                                <Button Grid.Column="0" 
                                        Command="{Binding PrintPreviewCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Height="40">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Eye" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource POS_Preview}"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Open Drawer -->
                                <Button Grid.Column="2" 
                                        Command="{Binding OpenDrawerCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Height="40">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CashRegister" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource POS_CashDrawer}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Numeric Keypad Popup -->
            <Popup IsOpen="{Binding IsNumericKeypadOpen}" 
                   Placement="Center" 
                   StaysOpen="True"
                   AllowsTransparency="True">
                <controls:NumericKeypad DataContext="{Binding}"/>
            </Popup>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>

