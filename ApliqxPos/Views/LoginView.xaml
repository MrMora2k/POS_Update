<Window x:Class="ApliqxPos.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ApliqxPos.ViewModels"
        mc:Ignorable="d"
        Title="تسجيل الدخول" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border Background="{DynamicResource MaterialDesignPaper}"
            CornerRadius="16"
            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
            BorderThickness="1">
        <Grid Margin="32">
            <StackPanel VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="AccountCircle" Width="80" Height="80" 
                                       HorizontalAlignment="Center" 
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                                       Margin="0,0,0,24"/>

                <TextBlock Text="{Binding IsRegistrationMode, Converter={StaticResource BoolToTextConverter}, ConverterParameter='إنشاء حساب المالك|تسجيل الدخول'}" 
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="اسم المستخدم"
                         Margin="0,0,0,16"/>

                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             materialDesign:HintAssist.Hint="كلمة المرور"
                             Margin="0,0,0,16"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <PasswordBox x:Name="ConfirmPasswordBox"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             materialDesign:HintAssist.Hint="تأكيد كلمة المرور"
                             Margin="0,0,0,24"
                             Visibility="{Binding IsRegistrationMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                <Button Command="{Binding LoginCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="{Binding IsRegistrationMode, Converter={StaticResource BoolToTextConverter}, ConverterParameter='إنشاء الحساب|دخول'}"
                        Height="45"
                        FontSize="16"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True"
                                 Width="24" Height="24"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ErrorBrush}"/>
                </StackPanel>
            </StackPanel>

            <Button Style="{StaticResource MaterialDesignIconButton}"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    IsCancel="True"
                    Click="CloseButton_Click">
                <materialDesign:PackIcon Kind="Close"/>
            </Button>
        </Grid>
    </Border>
</Window>
