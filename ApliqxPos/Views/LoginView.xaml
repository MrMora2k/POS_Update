<Window x:Class="ApliqxPos.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ApliqxPos.ViewModels"
        Title="تسجيل الدخول" Height="540" Width="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border CornerRadius="20" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Branding -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6C3EE8" Offset="0"/>
                        <GradientStop Color="#3B82F6" Offset="0.6"/>
                        <GradientStop Color="#06B6D4" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Decorative Circles -->
                    <Ellipse Width="250" Height="250" Opacity="0.08"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-80,-80,0,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="White"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="180" Height="180" Opacity="0.1"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-60,-60">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="White"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <!-- Logo/Icon -->
                        <Border Width="90" Height="90" CornerRadius="22"
                                HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.15"/>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="CashRegister" Width="50" Height="50"
                                                     Foreground="White" HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="ApliqX POS" FontSize="30" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="نظام نقاط البيع المتكامل" FontSize="14"
                                   Foreground="#BBDEFB" HorizontalAlignment="Center"
                                   Margin="0,8,0,32"/>

                        <!-- Features -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="CheckCircle" Width="20" Height="20"
                                                         Foreground="#A5F3FC" VerticalAlignment="Center"/>
                                <TextBlock Text="إدارة متكاملة للمبيعات" Foreground="White"
                                           Margin="10,0,0,0" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="CheckCircle" Width="20" Height="20"
                                                         Foreground="#A5F3FC" VerticalAlignment="Center"/>
                                <TextBlock Text="وضع المطعم والتوصيل" Foreground="White"
                                           Margin="10,0,0,0" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" Width="20" Height="20"
                                                         Foreground="#A5F3FC" VerticalAlignment="Center"/>
                                <TextBlock Text="طباعة ذكية متعددة الطابعات" Foreground="White"
                                           Margin="10,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Version Bottom Left -->
                    <TextBlock Text="{Binding AppVersion}" Foreground="#80DEEA" FontSize="11"
                               VerticalAlignment="Bottom" HorizontalAlignment="Left"
                               Margin="20,0,0,20" Opacity="0.7"/>
                </Grid>
            </Border>

            <!-- Right Panel: Login Form -->
            <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
                <Grid>
                    <!-- Close Button -->
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            VerticalAlignment="Top" HorizontalAlignment="Left"
                            Click="CloseButton_Click" Margin="8,8,0,0" Opacity="0.6">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>

                    <StackPanel VerticalAlignment="Center" Margin="40,0">
                        <!-- Header -->
                        <TextBlock Text="{Binding IsRegistrationMode, Converter={StaticResource BoolToTextConverter}, ConverterParameter='إنشاء الحساب|مرحباً بك'}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding IsRegistrationMode, Converter={StaticResource BoolToTextConverter}, ConverterParameter='أنشئ حساب المالك للمتابعة|سجّل دخولك للمتابعة'}"
                                   FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,32"/>

                        <!-- Username -->
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="اسم المستخدم"
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                 materialDesign:TextFieldAssist.LeadingIcon="Account"
                                 Margin="0,0,0,16"/>

                        <!-- Password -->
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     materialDesign:HintAssist.Hint="كلمة المرور"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="Lock"
                                     Margin="0,0,0,16"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>

                        <!-- Confirm Password (Registration Only) -->
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     materialDesign:HintAssist.Hint="تأكيد كلمة المرور"
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                                     materialDesign:TextFieldAssist.LeadingIcon="LockCheck"
                                     Margin="0,0,0,16"
                                     Visibility="{Binding IsRegistrationMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                        <!-- Remember Me (Login Only) -->
                        <CheckBox Content="تذكرني"
                                  IsChecked="{Binding RememberMe}"
                                  Margin="0,0,0,24"
                                  Visibility="{Binding IsRegistrationMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <!-- Login Button -->
                        <Button Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Height="48" FontSize="15" FontWeight="SemiBold">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GradientButton}">
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="LoginVariant" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding IsRegistrationMode, Converter={StaticResource BoolToTextConverter}, ConverterParameter='إنشاء الحساب|تسجيل الدخول'}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Status / Loader -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,16,0,0" MinHeight="24">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         IsIndeterminate="True" Width="22" Height="22"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"
                                       TextWrapping="Wrap" FontSize="13"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

