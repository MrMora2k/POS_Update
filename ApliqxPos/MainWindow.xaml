<Window x:Class="ApliqxPos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ApliqxPos.ViewModels"
        xmlns:views="clr-namespace:ApliqxPos.Views"
        xmlns:converters="clr-namespace:ApliqxPos.Converters"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Height="900" Width="1500"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource BackgroundGradient}"
        FlowDirection="{Binding Localization.CurrentFlowDirection}"
        FontFamily="{DynamicResource AppFontFamily}"
        TextElement.FontSize="{DynamicResource AppFontSize}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}">
    
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <materialDesign:DialogHost Identifier="RootDialog" SnackbarMessageQueue="{Binding MessageQueue}">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="280"/>
                <!-- Main Content -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- =============================================== -->
            <!-- Premium Sidebar with Gradient                  -->
            <!-- =============================================== -->
            <Border Grid.Column="0" 
                    Background="{StaticResource SidebarGradient}"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- App Logo & Branding -->
                    <Border Grid.Row="0" Padding="24,32,24,24">
                        <StackPanel>
                            <!-- Logo Circle with Gradient -->
                            <Border Width="80" Height="80" CornerRadius="40" Margin="0,0,0,16"
                                    Background="{StaticResource PrimaryGradient}">
                                <materialDesign:PackIcon Kind="PointOfSale" 
                                                          Width="40" Height="40" 
                                                          Foreground="White"
                                                          HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock Text="{DynamicResource AppName}" 
                                       Style="{StaticResource HeaderText}"
                                       HorizontalAlignment="Center"
                                       FontSize="26"/>
                            <TextBlock Text="{DynamicResource AppDescription}" 
                                       Style="{StaticResource CaptionText}"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0"
                                       Opacity="0.7"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Navigation Menu -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                        <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="12,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding ViewName}"
                                            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#1A7C3AED"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Icon with subtle background -->
                                            <Border Grid.Column="0" 
                                                    Width="36" Height="36" 
                                                    CornerRadius="10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                
                                                <materialDesign:PackIcon Kind="{Binding IconKind}" 
                                                                          Width="20" Height="20"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                            </Border>
                                            
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Title}" 
                                                       VerticalAlignment="Center"
                                                       FontSize="14">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="Medium"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Bottom Controls -->
                    <Border Grid.Row="2" Padding="16,20" Background="{StaticResource GlassBrush}">
                        <StackPanel>
                            <!-- Language & Theme Toggles -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Language Toggle -->
                                <Button Grid.Column="0" 
                                        Command="{Binding ToggleLanguageCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Height="44"
                                        Margin="4"
                                        ToolTip="{DynamicResource Settings_Language}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Translate" Width="22" Height="22" 
                                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding Localization.CurrentLanguage, Converter={StaticResource UpperCaseConverter}}"
                                                   Margin="8,0,0,0" 
                                                   VerticalAlignment="Center" 
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Theme Toggle -->
                                <Button Grid.Column="1" 
                                        Command="{Binding ToggleThemeCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Height="44"
                                        Margin="4"
                                        ToolTip="{DynamicResource Settings_Theme}">
                                    <materialDesign:PackIcon Width="22" Height="22" 
                                                              Foreground="{StaticResource TextSecondaryBrush}">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="WeatherNight"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.Theme.IsDarkMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                        <Setter Property="Kind" Value="WhiteBalanceSunny"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </Button>
                            </Grid>

                            <!-- Logout Button -->
                            <Button Command="{Binding LogoutCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Height="44"
                                    Margin="4,8,4,0"
                                    ToolTip="تسجيل الخروج">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Logout" Width="22" Height="22" 
                                                           Foreground="{DynamicResource ErrorBrush}"/>
                                    <TextBlock Text="تسجيل الخروج"
                                               Margin="12,0,0,0" 
                                               VerticalAlignment="Center" 
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Foreground="{DynamicResource ErrorBrush}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- =============================================== -->
            <!-- Main Content Area                              -->
            <!-- =============================================== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Top Header Bar -->
                <Border Grid.Row="0" Padding="32,24" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Page Title & Breadcrumb -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding PageTitle}" 
                                       Style="{StaticResource HeaderText}"/>
                            <TextBlock Text="{DynamicResource AppDescription}" 
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,4,0,0"
                                       Opacity="0.6"/>
                        </StackPanel>
                        
                        <!-- Right Actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <!-- Search Button -->
                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                    Width="48" Height="48"
                                    Margin="8,0">
                                <materialDesign:PackIcon Kind="Magnify" Width="24" Height="24" 
                                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                            
                            <!-- Notifications -->
                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                    Width="48" Height="48"
                                    Margin="8,0">
                                <materialDesign:PackIcon Kind="BellOutline" Width="24" Height="24"
                                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                            
                            <!-- User Avatar -->
                            <Border Width="44" Height="44" CornerRadius="22" Margin="12,0,0,0"
                                    Background="{StaticResource CyanGradient}">
                                <TextBlock Text="{DynamicResource Label_UserInitial}" FontSize="18" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Content Scroll Area -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="32,0,32,32">
                    <Grid>
                    
                    <!-- Dashboard View -->
                    <Grid Visibility="{Binding CurrentView, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Dashboard, FallbackValue=Visible}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Stats Cards Row -->
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Today's Sales Card -->
                            <Border Grid.Column="0" Style="{StaticResource PremiumCard}" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource Report_TotalSales}" 
                                                   Style="{StaticResource CaptionText}"/>
                                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="12"
                                                Background="{StaticResource PrimaryGradient}">
                                            <materialDesign:PackIcon Kind="CashMultiple" 
                                                                      Width="24" Height="24" 
                                                                      Foreground="White"
                                                                      HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    
                                    <TextBlock Grid.Row="1" Text="{Binding TotalSales, FallbackValue=0}" 
                                               Style="{StaticResource PriceText}"
                                               FontSize="28"
                                               Margin="0,12,0,0"/>
                                    
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{DynamicResource Currency_IQD}" 
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Profit Card -->
                            <Border Grid.Column="1" Style="{StaticResource PremiumCard}" Margin="6,0,6,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource Report_TotalProfit}" 
                                                   Style="{StaticResource CaptionText}"/>
                                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="12"
                                                Background="{StaticResource SuccessGradient}">
                                            <materialDesign:PackIcon Kind="TrendingUp" 
                                                                      Width="24" Height="24" 
                                                                      Foreground="White"
                                                                      HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    
                                    <TextBlock Grid.Row="1" Text="{Binding TotalProfit, FallbackValue=0}" 
                                               Style="{StaticResource PriceText}"
                                               FontSize="28"
                                               Margin="0,12,0,0"/>
                                    
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{DynamicResource Currency_IQD}" 
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Customers Card -->
                            <Border Grid.Column="2" Style="{StaticResource PremiumCard}" Margin="6,0,6,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource Nav_Customers}" 
                                                   Style="{StaticResource CaptionText}"/>
                                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="12"
                                                Background="{StaticResource CyanGradient}">
                                            <materialDesign:PackIcon Kind="AccountGroup" 
                                                                      Width="24" Height="24" 
                                                                      Foreground="White"
                                                                      HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    
                                    <TextBlock Grid.Row="1" Text="{Binding TotalCustomers, FallbackValue=0}" 
                                               Style="{StaticResource PriceText}"
                                               FontSize="28"
                                               Margin="0,12,0,0"/>
                                    
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{DynamicResource Customer}" 
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Debts Card -->
                            <Border Grid.Column="3" Style="{StaticResource PremiumCard}" Margin="12,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource Nav_Debts}" 
                                                   Style="{StaticResource CaptionText}"/>
                                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="12"
                                                Background="{StaticResource WarningGradient}">
                                            <materialDesign:PackIcon Kind="CreditCardClock" 
                                                                      Width="24" Height="24" 
                                                                      Foreground="White"
                                                                      HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    
                                    <TextBlock Grid.Row="1" Text="{Binding TotalDebts, FallbackValue=0}" 
                                               Style="{StaticResource PriceText}"
                                               FontSize="28"
                                               Foreground="{StaticResource WarningBrush}"
                                               Margin="0,12,0,0"/>
                                    
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{DynamicResource Currency_IQD}" 
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                        
                        <!-- Quick Actions & Welcome -->
                        <Grid Grid.Row="1" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Welcome Card with Gradient Overlay -->
                            <Border Grid.Column="0" CornerRadius="16" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                        <GradientStop Color="#4F46E5" Offset="0.5"/>
                                        <GradientStop Color="#06B6D4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <!-- Pattern Overlay -->
                                    <Border CornerRadius="16" Opacity="0.1">
                                        <Border.Background>
                                            <VisualBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                                                <VisualBrush.Visual>
                                                    <Ellipse Width="8" Height="8" Fill="White"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Border.Background>
                                    </Border>
                                    
                                    <!-- Content -->
                                    <StackPanel Margin="32">
                                        <TextBlock Text="{DynamicResource Dashboard_Welcome}" 
                                                   FontSize="26" FontWeight="Bold" 
                                                   Foreground="White"/>
                                        <TextBlock Text="{DynamicResource Dashboard_WelcomeSub}"
                                                   FontSize="14" Foreground="#E0E0E0" 
                                                   TextWrapping="Wrap"
                                                   Margin="0,12,0,24"/>
                                        
                                        <StackPanel Orientation="Horizontal">
                                            <Button Command="{Binding NavigateCommand}"
                                                    CommandParameter="POS"
                                                    Background="White"
                                                    Foreground="#5D3FD3"
                                                    FontWeight="Bold"
                                                    Padding="24,12"
                                                    materialDesign:ButtonAssist.CornerRadius="12">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="PointOfSale" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{DynamicResource Nav_POS}" 
                                                               Foreground="#5D3FD3"
                                                               FontWeight="Bold"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            
                                            <Button Command="{Binding NavigateCommand}"
                                                    CommandParameter="Products"
                                                    Background="Transparent"
                                                    BorderBrush="White"
                                                    BorderThickness="2"
                                                    Foreground="White"
                                                    FontWeight="SemiBold"
                                                    Padding="24,12"
                                                    Margin="12,0,0,0"
                                                    materialDesign:ButtonAssist.CornerRadius="12">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Package" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{DynamicResource Nav_Products}"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Quick Stats -->
                            <Border Grid.Column="1" Style="{StaticResource PremiumCard}" Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Dashboard_QuickActions}" 
                                               Style="{StaticResource SubheaderText}"
                                               Margin="0,0,0,16"/>
                                    
                                    <!-- Quick Action Buttons -->
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Products"
                                            HorizontalContentAlignment="Stretch"
                                            Height="48"
                                            Margin="0,6"
                                            Padding="16,0"
                                            materialDesign:ButtonAssist.CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" 
                                                                      Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{DynamicResource Product_NewProduct}" 
                                                       Margin="12,0" VerticalAlignment="Center"/>
                                            <materialDesign:PackIcon Grid.Column="2" Kind="ChevronLeft" Width="18" Height="18"
                                                                      Foreground="{StaticResource TextMutedBrush}"/>
                                        </Grid>
                                    </Button>
                                    
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Customers"
                                            HorizontalContentAlignment="Stretch"
                                            Height="48"
                                            Margin="0,6"
                                            Padding="16,0"
                                            materialDesign:ButtonAssist.CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="AccountPlus" Width="20" Height="20" 
                                                                      Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{DynamicResource Customer_NewCustomer}" 
                                                       Margin="12,0" VerticalAlignment="Center"/>
                                            <materialDesign:PackIcon Grid.Column="2" Kind="ChevronLeft" Width="18" Height="18"
                                                                      Foreground="{StaticResource TextMutedBrush}"/>
                                        </Grid>
                                    </Button>
                                    
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Reports"
                                            HorizontalContentAlignment="Stretch"
                                            Height="48"
                                            Margin="0,6"
                                            Padding="16,0"
                                            materialDesign:ButtonAssist.CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="ChartBar" Width="20" Height="20" 
                                                                      Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{DynamicResource Report_Daily}" 
                                                       Margin="12,0" VerticalAlignment="Center"/>
                                            <materialDesign:PackIcon Grid.Column="2" Kind="ChevronLeft" Width="18" Height="18"
                                                                      Foreground="{StaticResource TextMutedBrush}"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                    </Grid>
                    
                    <!-- POS View -->
                    <views:PosView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=POS}"/>
                    
                    <!-- Products View -->
                    <views:ProductsView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Products}"/>
                    
                    <!-- Customers View -->
                    <views:CustomersView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Customers}"/>
                    
                    <!-- Inventory View -->
                    <views:InventoryView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Inventory}"/>
                    
                    <!-- Sales View -->
                    <views:SalesView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Sales}"/>
                    
                    <!-- Debts View -->
                    <views:DebtsView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Debts}"/>
                    
                    <!-- Reports View -->
                    <views:ReportsView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Reports}"/>
                    
                    <!-- Settings View -->
                    <views:SettingsView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Settings}"/>
                    
                    <!-- Categories View -->
                    <views:CategoriesView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Categories}"/>

                    <!-- Users View -->
                    <views:UsersView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=Users}"
                                     DataContext="{Binding DataContext.UsersViewModel, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    
                    </Grid>
                </ScrollViewer>
            </Grid>
            
        </Grid>
    </materialDesign:DialogHost>
</Window>
