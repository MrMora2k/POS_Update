<UserControl x:Class="ApliqxPos.Controls.NumericKeypad"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="280">
    
    <UserControl.Resources>
        <Style x:Key="KeypadButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="12"
            Width="260">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="8" BlurRadius="20" Opacity="0.4"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Close Button/Display area -->
                <RowDefinition Height="*"/>    <!-- Main Pad -->
            </Grid.RowDefinitions>

            <!-- Keyboard Layout -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <UniformGrid Grid.RowSpan="4" Grid.ColumnSpan="3" Rows="4" Columns="3">
                    <Button Content="1" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    <Button Content="2" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    <Button Content="3" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    
                    <Button Content="4" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    <Button Content="5" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    <Button Content="6" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    
                    <Button Content="7" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    <Button Content="8" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    <Button Content="9" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    
                    <Button Content="C" Style="{StaticResource KeypadButton}" Click="Btn_Clear" Foreground="{StaticResource DangerBrush}"/>
                    <Button Content="0" Style="{StaticResource KeypadButton}" Click="Btn_Click"/>
                    <Button Style="{StaticResource KeypadButton}" Click="Btn_Backspace">
                        <materialDesign:PackIcon Kind="BackspaceOutline" Width="20" Height="20"/>
                    </Button>
                </UniformGrid>
            </Grid>

            <!-- Action Row -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                    <materialDesign:PackIcon Kind="Numeric" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="كمية المنتج" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="8,0,0,0"/>
                </StackPanel>
                
                <Button Grid.Column="1" 
                        Click="Btn_Done"
                        Style="{StaticResource MaterialDesignIconButton}" 
                        Foreground="{StaticResource AccentBrush}">
                    <materialDesign:PackIcon Kind="CheckBold" Width="24" Height="24"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
