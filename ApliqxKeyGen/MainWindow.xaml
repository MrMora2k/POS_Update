<Window x:Class="ApliqxKeyGen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ApliqxKeyGen"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource MaterialDesignPaper}" Padding="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <TextBlock Text="ApliqX Key Generator" 
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <Button Content="Generate Random Key"
                        Click="GenerateKey_Click"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,0,16"/>

                <TextBox x:Name="KeyTextBox"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="License Key"
                         IsReadOnly="False"
                         Margin="0,0,0,16"/>

                <TextBox x:Name="UsernameTextBox"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Username"
                         Margin="0,0,0,16"/>

                <TextBox x:Name="MaxDevicesTextBox"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Max Devices"
                         Text="1"
                         Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 materialDesign:HintAssist.Hint="Password"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBox x:Name="VisiblePasswordBox"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Password"
                             Visibility="Collapsed"
                             TextChanged="VisiblePasswordBox_TextChanged"/>

                    <ToggleButton x:Name="ShowPasswordToggle"
                                  Grid.Column="1"
                                  Style="{StaticResource MaterialDesignActionToggleButton}"
                                  Margin="8,0,0,0"
                                  Checked="ShowPasswordToggle_Checked"
                                  Unchecked="ShowPasswordToggle_Unchecked">
                        <ToggleButton.Content>
                            <materialDesign:PackIcon Kind="Eye" />
                        </ToggleButton.Content>
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="EyeOff" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                    </ToggleButton>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="CreateButton"
                            Content="Create License"
                            Click="CreateLicense_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="50"
                            Margin="0,0,8,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="ResetActivationButton"
                                Content="Reset"
                                Click="ResetActivation_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Height="50"
                                Margin="0,0,8,0"
                                Visibility="Collapsed"
                                Foreground="OrangeRed"
                                ToolTip="Reset Activations"/>

                        <Button x:Name="CancelEditButton"
                                Content="Cancel"
                                Click="CancelEdit_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="50"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <ProgressBar x:Name="LoadingBar"
                             Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Margin="0,16,0,0"/>

                <TextBlock x:Name="StatusTextBlock"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource MaterialDesignPaper}" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <Button Content="Refresh Data" Click="Refresh_Click" Style="{StaticResource MaterialDesignFlatButton}"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="LicensesGrid" ItemsSource="{Binding Licenses}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*"/>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                        <DataGridTextColumn Header="Password" Binding="{Binding PlainPassword}" Width="120"/>
                        <DataGridTextColumn Header="Max Devices" Binding="{Binding MaxDevices}" Width="90"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                        <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt}" Width="150"/>
                        <DataGridTemplateColumn Header="Actions" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" ToolTip="Copy Details" Click="CopyDetails_Click" Height="30" Width="30">
                                            <materialDesign:PackIcon Kind="ContentCopy" Width="16" Height="16"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" ToolTip="Edit" Click="EditLicense_Click" Height="30" Width="30" Margin="4,0">
                                            <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}" ToolTip="Delete" Click="DeleteLicense_Click" Height="30" Width="30" Foreground="Red">
                                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
